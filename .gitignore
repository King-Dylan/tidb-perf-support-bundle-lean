.DS_Store

# Local credentials/config. Keep these out of version control.
**/.db_config.json
*.pem
*.key

# Python/runtime artifacts.
**/.venv/
**/__pycache__/
*.py[cod]
*$py.class

# Local Go build outputs.
code/go-loadgen/go-loadgen
code/go-loadgen/go-loadgen-linux-amd64

# Local run noise.
**/logs/
*.log

# Large local database/client dumps, if any are produced during experiments.
*.sql.gz
*.dump
*.bak
